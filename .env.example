# Pexels API key (free at https://www.pexels.com/api/) — used for todo images.
# The app works without it; todos are simply created without an image.
PEXELS_API_KEY=your-pexels-key

# Anthropic API key — powers the AI task decomposition feature (✨).
# Optional: without it the decompose endpoint returns a friendly 503.
ANTHROPIC_API_KEY=your-anthropic-key
