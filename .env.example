# Pexels API key (free at https://www.pexels.com/api/) — used for todo images.
# The app works without it; todos are simply created without an image.
PEXELS_API_KEY=your-pexels-key

# OpenRouter API key — powers the AI task decomposition feature (✨),
# routed to a Claude model. Optional: without it the decompose endpoint
# returns a friendly 503. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key
# Optional: override the model (default: anthropic/claude-sonnet-4.5)
# OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
