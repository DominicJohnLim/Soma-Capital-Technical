// Production schema for Vercel — identical models to prisma/schema.prisma,
// but Postgres (SQLite doesn't persist on Vercel's serverless filesystem).
// Local dev keeps using schema.prisma (SQLite). Selected at build time by the
// `vercel-build` script via `--schema`.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Neon on Vercel: pooled (pgbouncer-safe) URL for serverless runtime queries,
  // direct URL for schema pushes/migrations. Both are set by the Neon integration.
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Todo {
  id           Int              @id @default(autoincrement())
  title        String
  createdAt    DateTime         @default(now())
  dueDate      DateTime?
  imageUrl     String?
  imageAlt     String?
  durationDays Int              @default(1)
  done         Boolean          @default(false)
  dependencies TodoDependency[] @relation("TodoDependencies")
  dependents   TodoDependency[] @relation("DependentTodos")
}

model TodoDependency {
  id          Int  @id @default(autoincrement())
  todoId      Int
  dependsOnId Int
  todo        Todo @relation("TodoDependencies", fields: [todoId], references: [id], onDelete: Cascade)
  dependsOn   Todo @relation("DependentTodos", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([todoId, dependsOnId])
}
